{
  "name": "datafetch",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/JayFarei/datafetch.git"
  },
  "bin": {
    "datafetch": "./bin/datafetch.mjs"
  },
  "scripts": {
    "datafetch": "tsx src/cli.ts",
    "demo": "tsx src/cli.ts demo",
    "eval:skillcraft": "tsx src/eval/skillcraftFullDatafetch.ts",
    "datafetch:run": "tsx src/eval/runScript.ts",
    "eval:skillcraft:synthetic": "tsx src/eval/skillcraftDatafetch.ts",
    "eval:skillcraft:synthetic:live": "tsx src/eval/skillcraftDatafetch.ts --live",
    "eval:skillcraft:synthetic:live:fast": "tsx src/eval/skillcraftDatafetch.ts --live --warm-fast-path",
    "eval:skillcraft:synthetic:live:smoke": "tsx src/eval/skillcraftDatafetch.ts --live --smoke",
    "eval:skillcraft:prepare": "bash eval/skillcraft/scripts/prepare-skillcraft.sh",
    "eval:skillcraft:native:claw": "bash eval/skillcraft/scripts/run-native-claw-codex.sh",
    "eval:skillcraft:normalize": "tsx eval/skillcraft/scripts/normalize-results.ts",
    "eval:skillcraft:analyze": "tsx eval/skillcraft/scripts/analyze-results.ts",
    "eval:skillcraft:report": "tsx eval/skillcraft/scripts/build-report.ts",
    "eval:skillcraft:verify": "tsx eval/skillcraft/scripts/verify-harness.ts",
    "eval:skillcraft:preflight": "tsx eval/skillcraft/scripts/check-native-readiness.ts",
    "test": "tsx src/snippet/__smoke__.ts && tsx src/snippet/__sdk_import_smoke__.ts && tsx src/observer/__smoke__.ts && tsx src/bash/__smoke__.ts && vitest run",
    "test:unit": "vitest run",
    "typecheck": "tsc --noEmit",
    "acceptance": "bash scripts/acceptance/run-all.sh",
    "acceptance:help": "bash scripts/acceptance/run-all.sh --help",
    "api": "tsx watch src/server/server.ts",
    "api:once": "tsx src/server/server.ts",
    "web": "pnpm --dir web dev",
    "web:install": "pnpm --dir web install"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.92.0",
    "@flue/sdk": "^0.3.6",
    "@hono/node-server": "^2.0.1",
    "hono": "^4.12.16",
    "just-bash": "^2.14.4",
    "mongodb": "^6.21.0",
    "valibot": "^1.3.1"
  },
  "devDependencies": {
    "@flue/cli": "0.3.6",
    "@types/node": "^24.10.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  }
}
