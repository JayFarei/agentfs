{
  "name": "atlasfs-hackathon",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "atlasfs": "tsx src/cli.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "api": "tsx watch src/server/server.ts",
    "api:once": "tsx src/server/server.ts",
    "web": "pnpm --dir web dev",
    "web:install": "pnpm --dir web install",
    "demo": "pnpm api & pnpm web; kill %1 2>/dev/null"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.92.0",
    "@hono/node-server": "^2.0.1",
    "hono": "^4.12.16",
    "mongodb": "^6.21.0",
    "valibot": "^1.3.1"
  },
  "devDependencies": {
    "@flue/cli": "0.3.6",
    "@flue/sdk": "0.3.6",
    "@types/node": "^24.10.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  }
}
